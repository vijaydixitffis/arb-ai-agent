VITE_API_BASE_URL=http://localhost:8000

# Backend Configuration
# Options: 'supabase' or 'python'
# - 'supabase': Uses Supabase backend (requires Supabase configuration below)
# - 'python': Uses Python FastAPI backend (no Supabase configuration needed)
VITE_BACKEND_TYPE=python

# Supabase Configuration (only required if VITE_BACKEND_TYPE=supabase)
# VITE_SUPABASE_URL=your_supabase_project_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
